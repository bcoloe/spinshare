# ============================================================
# DATABASE
# ============================================================
# Local development (docker-compose):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spinshare

# Neon — direct connection (port 5432, bypasses pooler):
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>.us-east-1.aws.neon.tech/<dbname>?sslmode=require

# Neon — connection pooler (recommended for production, port 6543 / -pooler hostname).
# The app uses NullPool so Neon can auto-suspend; PgBouncer handles warm connection
# reuse on Neon's side. Find your pooler URL in the Neon console under
# Connection Details → Connection pooling.
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>-pooler.us-east-1.aws.neon.tech/<dbname>?sslmode=require

# ============================================================
# SECURITY
# ============================================================
SECRET_KEY=<min-32-char-random-string>

# ============================================================
# SPOTIFY
# ============================================================
SPOTIFY_CLIENT_ID=<spotify-client-id>
SPOTIFY_CLIENT_SECRET=<spotify-client-secret>
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/users/spotify/callback

# ============================================================
# APPLE MUSIC
# ============================================================
APPLE_MUSIC_TEAM_ID=<team-id>
APPLE_MUSIC_KEY_ID=<key-id>
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ============================================================
# FRONTEND
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# EMAIL
# ============================================================
SMTP_ENABLED=true
# options: resend or smtp
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@example.com
RESEND_API_KEY=<resend-api-key>

# SMTP fallback (set EMAIL_PROVIDER=smtp to use)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USE_TLS=true
#SMTP_USERNAME=<smtp-username>
#SMTP_PASSWORD=<smtp-password>
#SMTP_FROM=<smtp-from-address>

# ============================================================
# GITHUB INTEGRATION
# ============================================================
GITHUB_TOKEN=<github-pat>
GITHUB_REPO=<owner>/<repo>
