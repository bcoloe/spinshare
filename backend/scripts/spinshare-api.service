[Unit]
Description=SpinShare API
After=network.target

[Service]
Type=simple
User=spinshare
WorkingDirectory=/opt/spinshare/backend
ExecStart=/opt/spinshare/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
EnvironmentFile=/opt/spinshare/backend/.env
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
